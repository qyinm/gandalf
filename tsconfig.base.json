{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@qxinm/hem-core": ["packages/core/src/index.ts"],
      "@qxinm/hem-core/*.js": ["packages/core/src/*.ts"],
      "@qxinm/hem-core/scanners/*.js": ["packages/core/src/scanners/*.ts"],
      "@qxinm/hem-tui": ["apps/tui/src/index.ts"],
      "@qxinm/hem-tui/*.js": ["apps/tui/src/*.ts"],
      "@qxinm/hem-tui/components/*.js": ["apps/tui/src/components/*.tsx", "apps/tui/src/components/*.ts"],
      "@qxinm/hem-tui/wizards/*.js": ["apps/tui/src/wizards/*.ts"]
    }
  }
}
