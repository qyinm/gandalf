{
  "name": "gandalf-workspace",
  "version": "0.4.1",
  "private": true,
  "description": "Workspace for Gandalf CLI tooling.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "go build -o bin/gandalf ./cmd/gandalf",
    "typecheck": "echo \"Landing page moved to dedicated repo; no frontend typecheck step here.\"",
