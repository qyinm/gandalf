{
  "name": "gandalf-workspace",
  "version": "0.4.1",
  "private": true,
  "description": "Workspace for Gandalf landing and desktop apps.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --cwd apps/landing build && bun run --cwd apps/desktop build",
    "typecheck": "bun run --cwd apps/landing typecheck && bun run --cwd apps/desktop typecheck",
    "test": "bun run --cwd apps/desktop test",
    "check": "bun run typecheck && bun run build && bun run test",
    "rust:test": "cargo test --workspace",
    "rust:check": "cargo check --workspace",
    "go:test": "go test ./...",
    "go:build": "go build -o bin/gandalf ./cmd/gandalf",
    "desktop:dev": "bun run --cwd apps/desktop tauri dev",
    "desktop:build": "bun run --cwd apps/desktop tauri build",
    "install:smoke": "./scripts/install-smoke.sh",
    "dogfood:cross-machine": "bun scripts/cross-machine-dogfood.mjs",
    "dogfood:gate2": "bun scripts/gate2-demo.mjs",
    "demo:pain:vhs": "node scripts/run-gate2-vhs.mjs demo/pain.tape",
    "demo:fix:vhs": "node scripts/run-gate2-vhs.mjs demo/fix.tape",
    "demo:gate2:vhs": "bun run demo:pain:vhs && bun run demo:fix:vhs"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.15",
    "typescript": "^5.8.3"
  }
}
