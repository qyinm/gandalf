{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gandalf",
  "version": "0.3.3",
  "identifier": "dev.gandalf.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Gandalf",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active"
        },
        "trafficLightPosition": {
          "x": 18,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
