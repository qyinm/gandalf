{
  "name": "@qxinm/hem",
  "version": "0.3.3",
  "description": "Time Machine for AI coding agent setups.",
  "type": "module",
  "bin": {
    "hem": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./dist/tests/*.test.js",
    "prepublishOnly": "bun run build && bun run test",
    "prepack": "bun run build"
  },
  "publishConfig": {
