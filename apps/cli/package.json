{
  "name": "@qxinm/gandalf",
  "version": "0.4.0",
  "description": "[DEPRECATED] Use the Go binary (bin/gandalf or GitHub Releases). npm package kept until Go binary distribution is primary.",
  "type": "module",
  "bin": {
    "gandalf": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./dist/tests/*.test.js",
    "prepublishOnly": "bun run build && bun run test",
    "prepack": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "codex",
    "rollback",
    "mcp",
    "cli",
    "audit",
    "diff"
  ],
  "license": "MIT",
  "author": "qxinm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qyinm/gandalf.git"
  },
  "bugs": {
    "url": "https://github.com/qyinm/gandalf/issues"
  },
  "homepage": "https://github.com/qyinm/gandalf#readme",
  "dependencies": {
    "@qxinm/gandalf-core": "0.4.0",
    "@qxinm/gandalf-tui": "0.4.0",
    "react": "^19.2.6"
  },
  "engines": {
    "node": ">=22"
  }
}
