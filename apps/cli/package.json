  },
  "keywords": [
    "ai-agent",
    "mcp",
    "cli",
    "audit",
    "diff"
  ],
  "license": "MIT",
  "author": "qyinm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qyinm/hem.git"
  },
  "bugs": {
    "url": "https://github.com/qyinm/hem/issues"
  },
  "homepage": "https://github.com/qyinm/hem#readme",
  "dependencies": {
    "@qxinm/hem-core": "0.3.3",
    "@qxinm/hem-tui": "0.3.3",
    "react": "^19.2.6"
  },
  "engines": {
    "node": ">=22"
  }
}
