{
  "name": "@qxinm/hem-tui",
  "version": "0.3.3",
  "description": "Terminal UI surfaces for Hem.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./*.js": {
      "types": "./dist/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./components/*.js": {
      "types": "./dist/src/components/*.d.ts",
      "default": "./dist/src/components/*.js"
    },
    "./wizards/*.js": {
      "types": "./dist/src/wizards/*.d.ts",
      "default": "./dist/src/wizards/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test dist/tests/*.test.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@qxinm/hem-core": "0.3.3",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.6"
  },
  "engines": {
    "node": ">=22"
  }
}
