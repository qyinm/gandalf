---
const principles = [
  {
    label: "01",
    title: "Local-first.",
    body: "Your branches live in `~/.gandalf`. No cloud, no telemetry, no account required."
  },
  {
    label: "02",
    title: "Setup as text.",
    body: "Every snapshot is plain JSON. Diff with Git, share with your team, version with anything."
  },
  {
    label: "03",
    title: "Reversible.",
    body: "`gandalf restore` is the only thing that should change your config without you knowing."
  }
];
---

<section class="section manifesto">
  <div class="container">
    <p class="section-meta">
      <span class="section-meta__num">01</span> &nbsp;&mdash;&nbsp; Why Gandalf
    </p>

    <h2 class="section-title">
      Branches for the layer Git forgot.
    </h2>

    <p class="section-lede">
      Agents install MCP servers. Agents add skills. Agents edit hooks and permissions.
      The Codex setup on your Mac is a real surface — and it has no undo.
      Gandalf treats it like source code: save it, diff it, switch it, restore it.
    </p>

    <div class="manifesto__grid">
      {principles.map((p) => (
        <article class="principle">
          <span class="principle__label">{p.label}</span>
          <h3 class="principle__title">{p.title}</h3>
          <p class="principle__body" set:html={p.body.replace(/`([^`]+)`/g, '<code>$1</code>')} />
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .manifesto__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
  }

  .principle {
    padding: 28px 24px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .principle__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--muted-foreground);
    margin-bottom: 14px;
  }

  .principle__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.015em;
  }

  .principle__body {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  .principle__body code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--surface);
    padding: 1px 5px;
    border-radius: var(--radius-sm);
    color: var(--foreground);
  }

  @media (max-width: 768px) {
    .manifesto__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
