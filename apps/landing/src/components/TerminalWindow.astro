---
export interface Props {
  lines?: { command: string; prompt?: boolean }[];
  label?: string;
}

const { lines, label } = Astro.props;
const hasLines = Array.isArray(lines) && lines.length > 0;
---

<div class="terminal">
  <div class="terminal__bar">
    <span class="terminal__dot terminal__dot--red"></span>
    <span class="terminal__dot terminal__dot--yellow"></span>
    <span class="terminal__dot terminal__dot--green"></span>
    {label && <span class="terminal__label">{label}</span>}
  </div>

  <pre class="terminal__body">
    <code>
      {hasLines ? (
        lines!.map((line) => (
          <span class="terminal__line">
            {line.prompt === false ? (
              <span>{line.command}</span>
            ) : (
              <>
                <span class="terminal__prompt">$</span>
                <span> {line.command}</span>
              </>
            )}
          </span>
        ))
      ) : (
        <slot />
      )}
    </code>
  </pre>
</div>

<style>
  .terminal {
    background: #0a0a0a;
    border: 1px solid #27272a;
    border-radius: var(--radius);
    overflow: hidden;
    text-align: left;
    box-shadow: var(--shadow-terminal);
    min-width: 0;
    max-width: 100%;
  }

  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    background: #18181b;
    border-bottom: 1px solid #27272a;
  }

  .terminal__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border);
  }

  .terminal__dot--red { background: #71717a; }
  .terminal__dot--yellow { background: #71717a; }
  .terminal__dot--green { background: #71717a; }

  .terminal__label {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted-foreground);
    letter-spacing: 0;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .terminal__body {
    margin: 0;
    overflow: hidden;
    padding: 26px 26px 24px;
    max-width: 100%;
    min-width: 0;
  }

  .terminal__body code {
    font-family: var(--font-mono);
    font-size: clamp(0.78rem, 1vw, 0.9rem);
    line-height: 1.68;
    color: #d4d4d8;
    white-space: pre-wrap;
    display: block;
    overflow-wrap: anywhere;
    word-break: break-word;
    min-width: 0;
    max-width: 100%;
  }

  .terminal__line {
    display: block;
    line-height: 1.68;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .terminal__prompt {
    color: var(--brand);
    margin-right: 10px;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .terminal {
      width: 100%;
      max-width: 100%;
    }

    .terminal__body {
      padding: 18px 24px;
    }

    .terminal__body code {
      font-size: 0.72rem;
      line-height: 2;
    }
  }

  .terminal__add {
    color: #ffffff;
    font-weight: 500;
  }

  .terminal__mod {
    color: var(--foreground);
    font-weight: 500;
  }
</style>
