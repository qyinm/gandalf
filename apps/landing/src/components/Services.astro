---
const services = [
  {
    icon: 'camera',
    title: 'Save Setup',
    desc: 'Capture your current agent setup — prompts, MCP servers, skills, hooks, permissions, and settings — as a local restore point.',
  },
  {
    icon: 'search',
    title: 'Compare',
    desc: 'Compare any saved setup with your current setup. See MCP additions, skill removals, prompt edits, permission shifts, and env key changes.',
  },
  {
    icon: 'shield',
    title: 'Setup Notes',
    desc: 'Surface useful restore notes before applying changes: local commands, remote MCP URLs, required env keys, and manual setup gaps.',
  },
  {
    icon: 'folder-tree',
    title: 'Inventory',
    desc: 'See what each agent has installed right now: skills, MCP servers, hooks, permissions, project instructions, and config files.',
  },
  {
    icon: 'history',
    title: 'Restore',
    desc: 'Preview exactly what will change, save the current setup first, and restore the previous agent setup when experiments break.',
  },
  {
    icon: 'package',
    title: 'Profiles & Bundles',
    desc: 'Keep named local profiles and export them as portable .hem bundles for another Mac or a clean reinstall.',
  },
];

const iconPaths: Record<string, string> = {
  camera: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z M9 14a3 3 0 1 0 6 0 3 3 0 1 0-6 0',
  search: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  'folder-tree': 'M13 10h3a3 3 0 0 1 3 3v0a3 3 0 0 1-3 3h-3 M3 4v12a2 2 0 0 0 2 2h4 M13 16h3a3 3 0 0 1 3 3v0a3 3 0 0 1-3 3h-3 M5 4V2 M5 4v2 M5 4h14a1 1 0 0 1 1 1v1 M5 10h10',
  history: 'M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5 M12 7v5l4 2',
  package: 'M16.5 9.4 7.55 4.24 M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.29 7 12 12 20.71 7 M12 22V12',
};
---

<section class="services" id="services">
  <div class="container">
    <h2 class="section__title">Local Setup History</h2>
    <p class="section__subtitle">See what is installed, save restore points, compare changes, and recover the setup that worked.</p>
    <div class="services__grid">
      {services.map(s => (
        <div class="service-card">
          <div class="service-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[s.icon]} />
            </svg>
          </div>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
    padding: 4rem 0;
  }

  .services::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }

  .service-card {
    padding: 28px 26px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.3s;
    box-shadow: var(--shadow-sm);
  }

  .service-card:hover {
    border-color: var(--primary);
    background: var(--surface-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .service-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: 20px;
    background: color-mix(in srgb, var(--primary) 8%, transparent);
    border-radius: var(--radius-sm);
    color: var(--primary);
  }

  .service-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .service-card__desc {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>