---
const links = [
  { label: "Install", href: "#install" },
  { label: "Commands", href: "#primitives" },
  { label: "Docs", href: "/docs/bundle-format" },
  { label: "GitHub", href: "https://github.com/qyinm/gandalf" },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <a href="/" class="footer__brand" aria-label="Gandalf home">
        <img src="/gandalf-mark-bold-v2.svg" alt="" width="42" height="36" aria-hidden="true" />
        <span>Gandalf</span>
      </a>

      <nav class="footer__links" aria-label="Footer">
        {links.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>

      <p class="footer__meta">© {year} Gandalf</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 22px 0;
    background: rgb(255 255 255 / 0.86);
    color: var(--muted-foreground);
    font-size: 0.94rem;
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 44px;
    flex-wrap: nowrap;
  }

  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex: 0 0 auto;
    color: var(--foreground);
    font-family: var(--font-sans);
    font-size: 1.02rem;
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1;
  }

  .footer__brand img {
    display: block;
    width: 42px;
    height: 36px;
    object-fit: contain;
  }

  .footer__links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex: 1 1 auto;
    min-width: 0;
    white-space: nowrap;
  }

  .footer__links a {
    color: var(--muted-foreground);
    font-size: 0.94rem;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .footer__links a:hover {
    color: var(--foreground);
  }

  .footer__meta {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 16px 0;
      font-size: 0.86rem;
    }

    .footer__inner {
      align-items: center;
      justify-content: flex-start;
      gap: 14px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .footer__inner::-webkit-scrollbar {
      display: none;
    }

    .footer__links {
      justify-content: flex-start;
      gap: 14px;
      flex: 0 0 auto;
      width: auto;
    }

    .footer__brand {
      font-size: 0.98rem;
    }

    .footer__brand img {
      width: 34px;
      height: 29px;
    }

    .footer__links a {
      font-size: 0.86rem;
    }

    .footer__meta {
      display: none;
    }
  }

</style>
