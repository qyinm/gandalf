---
import CopyButton from './CopyButton';

const steps = [
  {
    number: '01',
    icon: 'search',
    title: 'Inspect',
    desc: 'Scan your project to detect agents, MCP servers, skills, hooks, env keys, and settings.',
    code: 'hem scan --project . --explain',
  },
  {
    number: '02',
    icon: 'camera',
    title: 'Save',
    desc: 'Create a baseline snapshot before you let agents install MCPs, skills, or hooks.',
    code: 'hem snapshot create --name baseline --metadata-only --project .',
  },
  {
    number: '03',
    icon: 'columns-2',
    title: 'Compare',
    desc: 'After changes, compare against baseline and inspect where each changed setting came from.',
    code: 'hem diff baseline current --project . && hem provenance current --project .',
  },
  {
    number: '04',
    icon: 'history',
    title: 'Restore',
    desc: 'Generate a dry-run plan, then restore only after you have seen the exact changes. Apply mode requires --experimental.',
    code: 'hem restore --snapshot baseline --dry-run --project .',
  },
  {
    number: '05',
    icon: 'package',
    title: 'Move',
    desc: 'Export a saved setup to a portable .hem bundle. Preview Mac readiness before applying content.',
    code: 'hem bundle export --name baseline --out backup.hem --project .',
  },
];

const iconPaths: Record<string, string> = {
  search: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  camera: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z M9 14a3 3 0 1 0 6 0 3 3 0 1 0-6 0',
  'columns-2': 'M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18',
  history: 'M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5 M12 7v5l4 2',
  package: 'M16.5 9.4 7.55 4.24 M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.29 7 12 12 20.71 7 M12 22V12',
};
---

<section class="guide" id="use">
  <div class="container">
    <h2 class="section__title">How to Use</h2>
    <p class="section__subtitle">Start with local history. Add cloud profiles later when you need multi-machine sync.</p>
    <div class="guide__steps">
      {steps.map(step => (
        <div class="guide__step">
          <div class="guide__step-marker">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[step.icon]} />
            </svg>
            <span class="guide__step-number">{step.number}</span>
          </div>
          <div class="guide__step-content">
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
            <div class="guide__code">
              <pre><code>{step.code}</code></pre>
              <CopyButton text={step.code} client:load />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .guide {
    position: relative;
    padding: 4rem 0;
  }

  .guide::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .guide__steps {
    max-width: 580px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .guide__step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .guide__step-marker {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 48px;
    padding-top: 4px;
    color: var(--brand);
  }

  .guide__step-number {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted-foreground);
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  .guide__step-content {
    flex: 1;
  }

  .guide__step-content h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .guide__step-content > p {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin-bottom: 12px;
    line-height: 1.6;
  }

  .guide__code {
    display: flex;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    max-width: 100%;
  }

  .guide__code pre {
    flex: 1;
    padding: 10px 14px;
    margin: 0;
    overflow-x: auto;
  }

  .guide__code code {
    font-family: var(--font-mono);
    font-size: clamp(0.7rem, 1.5vw, 0.8rem);
    color: var(--muted-foreground);
    word-break: break-all;
    white-space: pre-wrap;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .guide__step {
      flex-direction: column;
    }
    .guide__step-marker {
      flex-direction: row;
      width: auto;
      gap: 8px;
      padding-top: 0;
    }
  }
</style>