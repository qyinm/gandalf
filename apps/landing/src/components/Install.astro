---
import InstallTabs from './InstallTabs';
---

<section class="section install" id="install">
  <div class="container">
    <p class="section-meta">
      <span class="section-meta__num">03</span> &nbsp;&mdash;&nbsp; Install
    </p>

    <h2 class="section-title">
      One line. Two seconds.
    </h2>

    <p class="section-lede">
      Gandalf is a single static binary. No background daemon, no menu-bar app, no telemetry.
    </p>

    <InstallTabs client:load />

    <p class="install__verify">
      Then verify with <code>gandalf --version</code>.
    </p>
  </div>
</section>

<style is:global>
  .install-tabs {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    max-width: 680px;
  }

  .install-tabs__bar {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 6px 6px 12px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .install-tabs__tab {
    appearance: none;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
  }

  .install-tabs__tab:hover {
    color: var(--foreground);
  }

  .install-tabs__tab.is-active {
    background: var(--surface);
    color: var(--foreground);
  }

  .install-tabs__copy {
    margin-left: auto;
    appearance: none;
    background: transparent;
    border: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted-foreground);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    transition: color 0.15s, border-color 0.15s;
  }

  .install-tabs__copy:hover {
    color: var(--foreground);
    border-color: var(--foreground);
  }

  .install-tabs__pre {
    margin: 0;
    padding: 20px 16px;
    background: var(--surface);
    overflow-x: auto;
  }

  .install-tabs__pre code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--foreground);
  }

  .install-tabs__sigil {
    color: var(--brand); /* SURFACE 2/2 — the only brand use in content */
    margin-right: 4px;
    user-select: none;
  }
</style>

<style>
  .install__verify {
    margin-top: 20px;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .install__verify code {
    font-family: var(--font-mono);
    background: var(--surface);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    color: var(--foreground);
    font-size: 0.85rem;
  }
</style>
