---
import { GithubIcon } from 'lucide-react';
// Gandalf nav
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label="Gandalf home">
      <img src="/gandalf-mark-bold-v2.svg" alt="" class="nav__logo-mark" width="52" height="44" aria-hidden="true" />
      <span class="nav__logo-text">Gandalf</span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      <a href="/docs/bundle-format">Docs</a>
      <a href="https://github.com/qyinm/gandalf" target="_blank" rel="noopener">
        <GithubIcon size={15} strokeWidth={2} aria-hidden="true" />
        GitHub
      </a>
      <a href="#why">Why</a>
      <a href="#primitives">Commands</a>
      <a href="#install" class="nav__cta">
        Install
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: relative;
    z-index: 2;
    background: transparent;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(calc(100% - 64px), var(--max-width));
    margin: 0 auto;
    height: 76px;
    min-width: 0;
  }

  .nav__logo {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--foreground);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0;
    min-width: 0;
  }

  .nav__logo-mark {
    display: block;
    width: 52px;
    height: 44px;
    flex: 0 0 auto;
    object-fit: contain;
  }

  .nav__logo-text {
    color: var(--foreground);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 1.02rem;
    color: var(--muted-foreground);
    flex: 0 0 auto;
  }

  .nav__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 42px;
    gap: 6px;
    padding: 0 14px;
    border-radius: var(--radius-sm);
    transition: color 0.15s;
  }

  .nav__links a:hover {
    background: rgb(9 9 11 / 0.04);
    color: var(--foreground);
  }

  .nav__links svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nav__links .nav__cta {
    height: 40px;
    width: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 20px;
    margin-left: 14px;
    border-radius: var(--radius-sm);
    background: var(--foreground) !important;
    color: #ffffff !important;
    font-weight: 600;
    box-shadow: 0 12px 28px -18px rgb(0 0 0 / 0.8);
  }

  .nav__links .nav__cta:hover {
    color: #ffffff;
    background: var(--foreground-soft) !important;
  }

  @media (max-width: 1120px) {
    .nav__inner {
      width: min(calc(100% - 44px), var(--max-width));
    }

    .nav__links {
      gap: 10px;
      font-size: 0.94rem;
    }
  }

  @media (max-width: 480px) {
    .nav__inner {
      height: 70px;
    }

    .nav__logo {
      font-size: 1.12rem;
    }

    .nav__logo-mark {
      width: 48px;
      height: 40px;
    }

    .nav__links {
      gap: 14px;
      font-size: 1rem;
    }

    .nav__links a:nth-child(2),
    .nav__links a:nth-child(3),
    .nav__links a:nth-child(4),
    .nav__links .nav__cta {
      display: none;
    }
  }
</style>
