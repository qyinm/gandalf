---
const items = [
  {
    icon: 'list-tree',
    title: 'Inventory',
    desc: 'See every skill, MCP, hook, permission, and instruction file',
  },
  {
    icon: 'history',
    title: 'History',
    desc: 'Save deterministic restore points without writing commit messages',
  },
  {
    icon: 'columns-2',
    title: 'Compare',
    desc: 'View setup changes side by side before restoring anything',
  },
  {
    icon: 'rotate-ccw',
    title: 'Restore',
    desc: 'Go back to the setup that worked when an experiment breaks',
  },
  {
    icon: 'package',
    title: 'Move',
    desc: 'Carry a saved setup to another machine with a portable bundle',
  },
];

const iconPaths: Record<string, string> = {
  'list-tree': 'M13 10h3a3 3 0 0 1 3 3v0a3 3 0 0 1-3 3h-3 M3 4v12a2 2 0 0 0 2 2h4 M13 16h3a3 3 0 0 1 3 3v0a3 3 0 0 1-3 3h-3 M5 4V2 M5 4v2',
  history: 'M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5 M12 7v5l4 2',
  'columns-2': 'M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18',
  'rotate-ccw': 'M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5',
  package: 'M16.5 9.4 7.55 4.24 M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.29 7 12 12 20.71 7 M12 22V12',
};
---

<section class="philosophy">
  <div class="container">
    <h2 class="section__title">The Local-First Promise</h2>
    <p class="section__subtitle">
      Hem starts as a local tool. Your setup history stays on your machine unless you choose to export or sync it.
    </p>
    <div class="philosophy__grid">
      {items.map(item => (
        <div class="philosophy__item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={iconPaths[item.icon]} />
          </svg>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .philosophy {
    position: relative;
    text-align: center;
    padding: 4rem 0;
  }

  .philosophy::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .philosophy__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    max-width: 680px;
    margin: 0 auto;
  }

  .philosophy__item {
    flex: 0 1 calc(33.333% - 10px);
    min-width: 160px;
    max-width: 200px;
    padding: 28px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: all 0.3s;
    color: var(--primary);
    box-shadow: var(--shadow-sm);
  }

  .philosophy__item:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .philosophy__item h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--foreground);
    margin: 14px 0 6px;
  }

  .philosophy__item p {
    font-size: 0.8rem;
    color: var(--muted-foreground);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .philosophy__item {
      flex: 0 1 calc(50% - 10px);
    }
  }

  @media (max-width: 480px) {
    .philosophy__item {
      flex: 0 1 100%;
      max-width: 100%;
    }
  }
</style>