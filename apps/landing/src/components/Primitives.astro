---
const commands = [
  {
    verb: "save",
    sig: "gandalf save <name>",
    desc: "Snapshot every MCP, skill, hook, permission, and env key into a named branch."
  },
  {
    verb: "diff",
    sig: "gandalf diff <a> <b>",
    desc: "Side-by-side compare of two branches. Highlights added skills, removed MCPs, changed env keys."
  },
  {
    verb: "switch",
    sig: "gandalf switch <name>",
    desc: "Atomically apply a branch to your live ~/.codex setup. Survives partial failure."
  },
  {
    verb: "restore",
    sig: "gandalf restore <name>",
    desc: "One command back to a known-good state. The undo your agent setup never had."
  },
  {
    verb: "list",
    sig: "gandalf list",
    desc: "Show every branch with metadata: created, last applied, drift since save."
  },
  {
    verb: "export",
    sig: "gandalf export <name>",
    desc: "Emit a portable JSON bundle. Move setups across machines or share with a team."
  }
];
---

<section class="section primitives" id="primitives">
  <div class="container">
    <p class="section-meta">
      <span class="section-meta__num">02</span> &nbsp;&mdash;&nbsp; Primitives
    </p>

    <h2 class="section-title">
      Six verbs. The whole product.
    </h2>

    <p class="section-lede">
      Gandalf doesn't introduce new concepts — it borrows the ones you already use every day.
      Every command names what it does. Nothing else to learn.
    </p>

    <ol class="primitives__list">
      {commands.map((c, i) => (
        <li class="primitive">
          <span class="primitive__num">{String(i + 1).padStart(2, '0')}</span>
          <div class="primitive__body">
            <code class="primitive__sig">{c.sig}</code>
            <p class="primitive__desc">{c.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .primitives__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--border);
  }

  .primitive {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }

  .primitive__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-foreground);
    padding-top: 4px;
    letter-spacing: 0.06em;
  }

  .primitive__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .primitive__sig {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--foreground);
    font-weight: 500;
  }

  .primitive__desc {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    max-width: 60ch;
  }

  @media (max-width: 640px) {
    .primitive {
      grid-template-columns: 40px 1fr;
      gap: 16px;
    }
  }
</style>
