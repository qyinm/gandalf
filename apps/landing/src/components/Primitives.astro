---
import { Download, GitCompare, RotateCcw } from 'lucide-react';

const steps = [
  {
    label: "Snapshot",
    cmd: "gandalf snapshot create --name baseline",
    desc: "Save point.",
    note: "files + metadata",
  },
  {
    label: "Inspect",
    cmd: "gandalf diff baseline current",
    desc: "Drift check.",
    note: "semantic diff",
  },
  {
    label: "Restore",
    cmd: "gandalf restore --snapshot baseline --dry-run",
    desc: "Dry-run first.",
    note: "no write",
  },
];

const scope = [
  ["~/.codex/config.toml", "content-backed snapshot and restore"],
  ["user hooks / skills", "inventory and semantic evidence"],
  ["env values", "never copied, key inventory only"],
  ["unsupported files", "listed with reason before restore"],
];
---

<section class="section primitives" id="primitives">
  <div class="container">
    <div class="primitives__head">
      <div>
        <p class="section-meta">
          <span class="section-meta__num">02</span> &nbsp;/&nbsp; Rollback workflow
        </p>
        <h2 class="section-title">Before you say yes.</h2>
      </div>
    </div>

    <div class="workflow" aria-label="Gandalf rollback workflow">
      {steps.map((step, index) => (
        <article class="workflow__step">
          <span class="workflow__index">{String(index + 1).padStart(2, "0")}</span>
          {index === 0 && <Download className="workflow__icon" size={24} strokeWidth={2} aria-hidden="true" />}
          {index === 1 && <GitCompare className="workflow__icon" size={24} strokeWidth={2} aria-hidden="true" />}
          {index === 2 && <RotateCcw className="workflow__icon" size={24} strokeWidth={2} aria-hidden="true" />}
          <h3>{step.label}</h3>
          <code><span>$</span> {step.cmd}</code>
          <p>{step.desc}</p>
          <strong>{step.note}</strong>
        </article>
      ))}
    </div>

    <div class="scope-panel" aria-label="Gandalf supported scope">
      <div class="scope-panel__copy">
        <span>Supported scope</span>
        <strong>Conservative by default.</strong>
      </div>
      <div class="scope-panel__rows">
        {scope.map(([name, value]) => (
          <div>
            <code>{name}</code>
            <span>{value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .primitives {
    background: rgb(255 255 255 / 0.82);
  }

  .primitives__head {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(280px, 0.8fr);
    gap: 54px;
    align-items: end;
    margin-bottom: 34px;
  }

  .primitives__head .section-lede {
    margin-bottom: 0;
  }

  .workflow {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background: rgb(255 255 255 / 0.68);
  }

  .workflow__step {
    min-height: 292px;
    padding: 30px 28px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }

  .workflow__step:last-child {
    border-right: 0;
  }

  .workflow__index {
    color: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    margin-bottom: 54px;
  }

  .workflow__icon {
    width: 24px;
    height: 24px;
    margin-bottom: 18px;
    color: var(--brand);
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .workflow h3 {
    font-size: 1.3rem;
    font-weight: 650;
    margin-bottom: 14px;
  }

  .workflow code {
    display: block;
    width: 100%;
    padding: 13px 14px;
    border-radius: var(--radius-sm);
    background: #0b0b0c;
    color: #ffffff;
    font-size: 0.82rem;
    line-height: 1.55;
    overflow: visible;
    overflow-wrap: anywhere;
    white-space: normal;
  }

  .workflow code span {
    color: var(--brand);
  }

  .workflow p {
    margin-top: 20px;
    color: var(--muted-foreground);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .workflow strong {
    margin-top: auto;
    padding-top: 20px;
    color: var(--foreground);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .scope-panel {
    display: grid;
    grid-template-columns: 280px 1fr;
    margin-top: 18px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgb(255 255 255 / 0.68);
    overflow: hidden;
  }

  .scope-panel__copy {
    padding: 22px;
    border-right: 1px solid var(--border);
  }

  .scope-panel__copy span {
    display: block;
    margin-bottom: 8px;
    color: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .scope-panel__copy strong {
    display: block;
    max-width: 20ch;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .scope-panel__rows {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .scope-panel__rows div {
    display: grid;
    gap: 4px;
    padding: 15px 18px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .scope-panel__rows div:nth-child(2n) {
    border-right: 0;
  }

  .scope-panel__rows div:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .scope-panel__rows code {
    color: var(--foreground);
    font-size: 0.78rem;
  }

  .scope-panel__rows span {
    color: var(--muted-foreground);
    font-size: 0.84rem;
  }

  @media (max-width: 900px) {
    .primitives__head,
    .workflow,
    .scope-panel {
      grid-template-columns: 1fr;
    }

    .workflow__step,
    .scope-panel__copy {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .workflow__step {
      min-height: 0;
    }

    .workflow__index {
      margin-bottom: 28px;
    }

    .scope-panel__rows {
      grid-template-columns: 1fr;
    }

    .scope-panel__rows div,
    .scope-panel__rows div:nth-child(2n) {
      border-right: 0;
      border-bottom: 1px solid var(--border);
    }

    .scope-panel__rows div:last-child {
      border-bottom: 0;
    }
  }
</style>
