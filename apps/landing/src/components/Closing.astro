<section class="section closing">
  <div class="container closing__inner">
    <h2 class="closing__title">
      Get your setup back.
    </h2>
    <p class="closing__lede">
      Gandalf is free. Local-first. No account.
    </p>
    <div class="closing__actions">
      <a href="#install" class="btn btn--primary">
        Install Gandalf
      </a>
      <a href="https://github.com/usegandalf/gandalf" class="btn btn--outline" target="_blank" rel="noopener">
        Star on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .closing__inner {
    text-align: center;
    padding: 32px 0;
  }

  .closing__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }

  .closing__lede {
    font-size: 0.95rem;
    color: var(--muted-foreground);
    margin-bottom: 32px;
  }

  .closing__actions {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
</style>
