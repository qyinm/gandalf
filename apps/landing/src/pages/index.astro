---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Primitives from '../components/Primitives.astro';
import Install from '../components/Install.astro';
import Closing from '../components/Closing.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Gandalf — Branches for your AI agent setup"
  description="Gandalf saves, diffs, and restores the Codex setup on your Mac like a Git branch. MCP servers, skills, hooks, permissions, env keys — all versioned."
>
  <Nav />
  <main>
    <Hero />
    <Manifesto />
    <Primitives />
    <Install />
    <Closing />
  </main>
  <Footer />
</BaseLayout>
